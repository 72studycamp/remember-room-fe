# Optional browser-visible backend base URL.
# Leave this unset in Vercel so requests use same-origin rewrites.
VITE_API_BASE_URL=http://13.125.26.1

# Backend origin used to rewrite absolute asset URLs from the content API
# into same-origin /local-assets/... URLs when deployed on Vercel.
VITE_BACKEND_ORIGIN=http://13.125.26.1

# Local Vite-only proxy target. Used when VITE_API_BASE_URL is empty during local development.
VITE_DEV_API_PROXY_TARGET=http://localhost:8080
