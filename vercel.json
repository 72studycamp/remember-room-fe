{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "http://52.78.22.173:8080/api/:path*"
    },
    {
      "source": "/actuator/:path*",
      "destination": "http://52.78.22.173:8080/actuator/:path*"
    },
    {
      "source": "/local-assets/:path*",
      "destination": "http://52.78.22.173:8080/local-assets/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
